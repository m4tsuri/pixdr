diff --git a/host/lib/transport/libusb1_base.cpp b/host/lib/transport/libusb1_base.cpp
index 2bd80b8..76f5f7c 100644
--- a/host/lib/transport/libusb1_base.cpp
+++ b/host/lib/transport/libusb1_base.cpp
@@ -17,10 +17,25 @@
 #include <iostream>
 #include <memory>
 #include <mutex>
+#include <fcntl.h>
+#include <cstring>
+#include <linux/usbdevice_fs.h>
+#include <sys/ioctl.h>
 
 using namespace uhd;
 using namespace uhd::transport;
 
+// Android: when set >= 0, libusb_open() is replaced with libusb_wrap_sys_device()
+// and device enumeration returns a dummy B210 entry.
+extern "C" __attribute__((visibility("default"))) intptr_t g_android_usb_fd = -1;
+extern "C" __attribute__((visibility("default"))) const char* g_android_usb_path = nullptr;
+extern "C" __attribute__((visibility("default"))) uint16_t g_android_usb_vid = 0;
+extern "C" __attribute__((visibility("default"))) uint16_t g_android_usb_pid = 0;
+extern "C" __attribute__((visibility("default"))) bool g_android_usb_fw_loaded = false;
+// Keep a strong reference to the libusb session alive throughout the process
+// to prevent libusb_exit/libusb_init cycling which corrupts internal state.
+static libusb::session::sptr g_android_session;
+
 /***********************************************************************
  * libusb session
  **********************************************************************/
@@ -34,6 +49,9 @@ class libusb_session_impl : public libusb::session
 public:
     libusb_session_impl(void)
     {
+        if (g_android_usb_fd >= 0) {
+            libusb_set_option(NULL, LIBUSB_OPTION_NO_DEVICE_DISCOVERY);
+        }
         UHD_ASSERT_THROW(libusb_init(&_context) == 0);
 #if LIBUSB_API_VERSION >= 0x01000106
         libusb_set_option(_context,
@@ -172,6 +190,11 @@ class libusb_device_list_impl : public libusb::device_list
 public:
     libusb_device_list_impl(void)
     {
+        if (g_android_usb_fd >= 0) {
+            g_android_session = libusb::session::get_global_session();
+            return;
+        }
+
         libusb::session::sptr sess = libusb::session::get_global_session();
 
         // allocate a new list of devices
@@ -299,7 +322,48 @@ public:
     libusb_device_handle_impl(libusb::device::sptr dev)
     {
         _dev = dev;
-        UHD_ASSERT_THROW(libusb_open(_dev->get(), &_handle) == 0);
+        if (g_android_usb_fd >= 0) {
+            g_android_session = libusb::session::get_global_session();
+            int ret = libusb_wrap_sys_device(
+                g_android_session->get_context(),
+                g_android_usb_fd, &_handle);
+            if (ret != 0) {
+                throw uhd::os_error(
+                    std::string("libusb_wrap_sys_device failed: ") +
+                    libusb_error_name(ret));
+            }
+        } else {
+            UHD_ASSERT_THROW(libusb_open(_dev->get(), &_handle) == 0);
+        }
+    }
+
+    // Android: wrap a file descriptor from UsbManager instead of libusb_open
+    libusb_device_handle_impl(intptr_t fd)
+    {
+        // Detach kernel driver if any, then claim interface.
+        // Android's USB stack might have attached a driver that blocks
+        // vendor commands.
+        struct usbdevfs_ioctl detach;
+        detach.ifno = 0;
+        detach.ioctl_code = USBDEVFS_DISCONNECT;
+        detach.data = nullptr;
+        ioctl((int)fd, USBDEVFS_IOCTL, &detach);
+
+        g_android_session = libusb::session::get_global_session();
+        int ret = libusb_wrap_sys_device(
+            g_android_session->get_context(),
+            fd, &_handle);
+        if (ret != 0) {
+            throw uhd::os_error(
+                std::string("libusb_wrap_sys_device failed: ") +
+                libusb_error_name(ret));
+        }
+        // Get the libusb_device from the newly opened handle
+        libusb_device* dev = libusb_get_device(_handle);
+        if (dev) {
+            libusb_ref_device(dev);
+            _dev = libusb::device::sptr(new libusb_device_impl(dev));
+        }
     }
 
     ~libusb_device_handle_impl(void) override;
@@ -346,7 +410,14 @@ libusb_device_handle_impl::~libusb_device_handle_impl(void)
     for (size_t i = 0; i < _claimed.size(); i++) {
         libusb_release_interface(this->get(), _claimed[i]);
     }
-    libusb_close(_handle);
+    if (g_android_usb_fd >= 0) {
+        // Android: don't call libusb_close — it frees the dummy device
+        // allocated by our wrap_sys_device patch, triggering invalid free
+        // with hardened_malloc. The fd is closed when the process exits.
+        _handle = nullptr;
+    } else {
+        libusb_close(_handle);
+    }
 }
 
 libusb::device_handle::sptr libusb::device_handle::get_cached_handle(device::sptr dev)
@@ -380,6 +451,10 @@ libusb::device_handle::sptr libusb::device_handle::get_cached_handle(device::spt
     }
 }
 
+libusb::device_handle::sptr libusb::device_handle::make_from_fd(intptr_t fd)
+{
+    return sptr(new libusb_device_handle_impl(fd));
+}
 /***********************************************************************
  * libusb special handle
  **********************************************************************/
@@ -485,3 +560,38 @@ std::vector<usb_device_handle::sptr> usb_device_handle::get_device_list(
     }
     return handles;
 }
+
+// Android: create a libusb device handle from UsbManager fd, bypassing
+// libusb enumeration of /dev/bus/usb (blocked by SELinux on Android).
+std::vector<usb_device_handle::sptr> usb_device_handle::get_device_list(
+    uint16_t, uint16_t, int fd, const std::string&)
+{
+    std::vector<usb_device_handle::sptr> handles;
+
+    libusb_set_option(NULL, LIBUSB_OPTION_NO_DEVICE_DISCOVERY);
+    g_android_session = libusb::session::get_global_session();
+
+    libusb_device_handle* tmp = nullptr;
+    int ret = libusb_wrap_sys_device(g_android_session->get_context(), (intptr_t)fd, &tmp);
+    if (ret != 0 || tmp == nullptr) {
+        static int wrap_fail_logs = 0;
+        if (wrap_fail_logs++ < 5) {
+            UHD_LOGGER_WARNING("USB") << "Android libusb_wrap_sys_device fd=" << fd
+                                      << " failed: " << libusb_error_name(ret);
+        }
+        return handles;
+    }
+
+    libusb_device* dev = libusb_get_device(tmp);
+    if (!dev) {
+        UHD_LOGGER_WARNING("USB") << "Android libusb_wrap_sys_device returned null device";
+        return handles;
+    }
+
+    // Keep tmp open intentionally. Closing it unrefs/frees the dummy device
+    // created by the Android libusb patch and can trip hardened_malloc.
+    libusb_ref_device(dev);
+    libusb::device::sptr dev_ptr(new libusb_device_impl(dev));
+    handles.push_back(libusb::special_handle::make(dev_ptr));
+    return handles;
+}
